rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsIncomingData() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    match /users/{uid}/{collectionName}/{docId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /public_desa/{docId} {
      allow read: if signedIn();
      allow create, update: if ownsIncomingData();
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /public_rt/{docId} {
      allow read: if signedIn();
      allow create, update: if ownsIncomingData();
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /public_keluarga/{docId} {
      allow read: if signedIn();
      allow create, update: if ownsIncomingData();
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }
  }
}
